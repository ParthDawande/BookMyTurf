# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/bookmyturf?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-256-bit-secret-in-production
JWT_EXPIRATION=86400000

# ── Razorpay (test mode) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here

# ── Test fault injection ──────────────────────────────────────────────────────
# Forces a RazorpayException at the refund call site to exercise the 5C-3 catch path.
# Override via application-local.properties (gitignored) or this env var.
# Default: false. NEVER set true in production.
APP_TEST_FORCE_REFUND_FAILURE=false
